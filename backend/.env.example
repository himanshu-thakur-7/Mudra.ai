# ============================================================
#  ComplianceCopilot — Buildathon partner stack
#  The app runs today on OpenAI alone; every other partner is
#  key-ready and activates the moment you paste its key here.
# ============================================================

# ---- LLM provider layer ------------------------------------
# Agent pipeline prefers Hermes; auto-falls back to OpenAI until HERMES_API_KEY is set.
LLM_PROVIDER=hermes

# Nous Hermes — core reviewer / adjudicator / rewriter agents
HERMES_API_KEY=
HERMES_BASE_URL=https://inference-api.nousresearch.com/v1
HERMES_MODEL=Hermes-4-405B

# OpenAI (GPT-5.5) — vision/OCR preprocessing + fallback agent + embeddings
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1
OPENAI_PREPROCESS_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cloudflare AI Gateway — routes/monitors ALL LLM calls when set
# https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>
CF_AI_GATEWAY_BASE=

# ---- Convex (realtime DB + vector search + workflow state) -
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ---- Linkup (live regulatory search, called as a Hermes tool)
LINKUP_API_KEY=
LINKUP_BASE_URL=https://api.linkup.so/v1

# ---- ElevenLabs (voice copilot) ----------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ---- Razorpay (UPI AutoPay subscription; test keys are fine)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- app / infra -------------------------------------------
API_TOKEN=dev-token
PUBLIC_WEB_URL=http://localhost:4321
REDIS_URL=redis://localhost:6379/0
RETRIEVAL_BACKEND=sqlite   # sqlite | qdrant | convex

# Twilio WhatsApp sandbox (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
