# OpenAI (required for LLM review pipeline; deterministic checks work without it)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Static bearer token for the single-tenant MVP API
API_TOKEN=dev-token

# Where WhatsApp replies link to (the frontend)
PUBLIC_WEB_URL=http://localhost:5173

# Twilio WhatsApp sandbox (only needed for the WhatsApp webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
