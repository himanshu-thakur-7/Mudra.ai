    {
      "uid": "2dd66b92-3cab-5294-9cb5-8379968d3dc9",
      "clause_number": "5",
      "kind": "numbered",
      "page": 1,
      "paragraph_index": 6,
      "text": "5. A copy of this circular is available on SEBI website at www.sebi.gov.in under the categories\n“Legal → Circulars”.\nYours faithfully,\nVimal Bhatter\nDeputy General Manager\nCorporation Finance Department\nTel. No.: +91 22 4045 9386\nEmail id: vimalb@sebi.gov.in",
