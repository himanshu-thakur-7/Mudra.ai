      }
    },
    {
      "uid": "a30baced-9170-5f91-89b8-14a226179499",
      "clause_number": "5",
      "kind": "numbered",
      "page": 2,
      "paragraph_index": 6,
      "text": "5. This Circular is issued in exercise of the powers conferred under Section 11 (1) of the\nSecurities and Exchange Board of India Act, 1992, read with Regulation 51 of the Securities\nContracts (Regulation) (Stock Exchange and Clearing Corporations) Regulations, 2018 to\nprotect the interests of investors in securities and to promote the development of, and to\nregulate the securities market.",
      "metadata": {
