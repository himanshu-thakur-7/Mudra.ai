      }
    },
    {
      "uid": "20bdc04e-fea2-5718-8658-a3eb4d31fa5a",
      "clause_number": "5.2",
      "kind": "numbered",
      "page": 2,
      "paragraph_index": 8,
      "text": "5.2. Make amendments to the relevant bye-laws, rules and regulations for the\nimplementation of the terms of this circular, if necessary.",
      "metadata": {
        "regulator": "SEBI",
        "source_url": "https://www.sebi.gov.in/sebi_data/attachdocs/apr-2026/1775562977206.pdf",
        "source_page_url": "https://www.sebi.gov.in/legal/circulars/apr-2026/relaxation-from-the-applicability-of-sebi-master-circular-for-compliance-with-the-provisions-of-the-sebi-listing-obligations-and-disclosure-requirements-regulations-2015-on-non-compliance-with-the-_100787.html",
