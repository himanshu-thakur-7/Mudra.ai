    {
      "uid": "a3e3313e-7738-5ef1-b850-0dff5f1b11a2",
      "clause_number": "6",
      "kind": "numbered",
      "page": 2,
      "paragraph_index": 9,
      "text": "6. This Circular is issued in exercise of powers conferred under Section 11 and Section 11A\nof the Securities and Exchange Board of India Act, 1992 to protect the interests of\ninvestors in securities and to promote the development of, and to regulate the securities\nmarket.",
      "metadata": {
