      }
    },
    {
      "uid": "f3cee325-d056-5d2d-88ab-e15c1696902a",
      "clause_number": "10",
      "kind": "numbered",
      "page": 2,
      "paragraph_index": 13,
      "text": "10. This circular is available on SEBI website at www.sebi.gov.in under the\ncategory: ‘Legal → Circulars’.\nYours faithfully,\nDivya Hamirbasia\nDeputy General Manager\n022-26449293\ndivyah@sebi.gov.in",
