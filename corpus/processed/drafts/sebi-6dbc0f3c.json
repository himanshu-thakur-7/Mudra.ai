        "source_page_url": "https://www.sebi.gov.in/legal/circulars/jun-2026/ease-of-doing-business-relaxation-in-certification-requirement-for-persons-associated-with-investment-advice-paia-sales-and-other-non-core-services_102385.html",
        "raw_pdf_path": "../corpus/inbox/sebi/6dbc0f3c-1782299902147.pdf",
